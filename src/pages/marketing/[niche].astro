---
import Layout from '../../layouts/Layout.astro';
import { niches } from '../../data/niches.js';

export function getStaticPaths() {
  return niches.map((n) => ({ params: { niche: n.slug }, props: { n } }));
}

const { n } = Astro.props;
const title = `${n.h1} | Local Levers`;
const description = `${n.intro.slice(0, 150)}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: n.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const others = niches.filter((x) => x.slug !== n.slug);
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  </Fragment>

  <main class="pg">
    <section class="pg-hero">
      <div class="pg-inner">
        <a href="/" class="pg-brand">Local<span>Levers</span></a>
        <p class="pg-eyebrow">Voor {n.label}</p>
        <h1>{n.h1}</h1>
        <p class="pg-lead">{n.intro}</p>
        <a href="/check/" class="pg-cta">Vraag je gratis vindbaarheids-rapport aan &rarr;</a>
        <p class="pg-note">Gratis en vrijblijvend. Je ziet waar je staat op Google, Apple en in AI-antwoorden.</p>
      </div>
    </section>

    <section class="pg-block">
      <div class="pg-inner">
        <h2>Waar {n.label} klanten laten liggen</h2>
        <div class="pg-cards">
          {n.pains.map((pain) => (
            <article>
              <h3>{pain.h}</h3>
              <p>{pain.p}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="pg-block">
      <div class="pg-inner">
        <h2>Hoe wij het oplossen</h2>
        <div class="pg-pillars">
          <div>
            <span class="pg-pnum">01</span>
            <h3>Gevonden</h3>
            <p>Compleet Google Bedrijfsprofiel op je winstgevende behandeling, plus Bing, Apple Maps, directories en AI-zichtbaarheid. Zo verschijn je waar mensen zoeken.</p>
          </div>
          <div>
            <span class="pg-pnum">02</span>
            <h3>Gekozen</h3>
            <p>Een geautomatiseerd review-systeem en reputatie-opbouw, zodat de klant tussen jou en de concurrent voor jou kiest.</p>
          </div>
          <div>
            <span class="pg-pnum">03</span>
            <h3>Geen aanvraag gemist</h3>
            <p>Snelle opvolging op wat binnenkomt, ook buiten openingstijden, plus reactivatie van oude klanten. Meer uit wie je al hebt.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pg-block">
      <div class="pg-inner pg-faq">
        <h2>Veelgestelde vragen</h2>
        {n.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pg-block pg-cta-block">
      <div class="pg-inner">
        <h2>Zie waar je nu staat</h2>
        <p class="pg-lead">In een gratis vindbaarheids-rapport laten we zien waar je staat op je winstgevende behandeling, en wie er boven je staat. Geen kosten, geen verplichting.</p>
        <a href="/check/" class="pg-cta">Vraag je gratis vindbaarheids-rapport aan &rarr;</a>
      </div>
    </section>

    <footer class="pg-footer">
      <div class="pg-inner">
        <p>Local Levers &middot; Vindbaarheid en opvolging voor klinieken en behandel-salons</p>
        <p class="pg-links">
          Ook marketing voor {others.map((x, i) => (
            <>
              <a href={`/marketing/${x.slug}/`}>{x.label}</a>{i < others.length - 1 ? ', ' : '.'}
            </>
          ))}
        </p>
        <p class="pg-links">Meer uitleg? Lees de <a href="/gids/">kennisbank</a>.</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .pg { background: var(--dark); color: var(--color-foreground); font-family: 'Plus Jakarta Sans Variable', system-ui, sans-serif; }
  .pg-inner { max-width: 940px; margin: 0 auto; padding: 0 24px; }
  .pg-brand { font-family: 'Outfit Variable', sans-serif; font-weight: 800; font-size: 18px; color: #fff; text-decoration: none; }
  .pg-brand span { color: var(--green-bright); }
  .pg-hero { padding: 72px 0 64px; background: radial-gradient(700px circle at 80% 0%, rgba(34,169,107,0.18), transparent 55%), radial-gradient(500px circle at 0% 100%, rgba(26,122,84,0.14), transparent 60%), var(--dark); }
  .pg-eyebrow { margin-top: 40px; font-family: 'Outfit Variable', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--green-bright); }
  .pg h1 { font-family: 'Outfit Variable', sans-serif; font-size: clamp(32px, 5vw, 52px); font-weight: 800; line-height: 1.08; letter-spacing: -0.02em; margin: 14px 0 0; max-width: 18ch; }
  .pg-lead { font-size: 17px; line-height: 1.6; color: var(--light-muted); margin-top: 18px; max-width: 62ch; }
  .pg-cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 26px; background: var(--green-bright); color: #08130d; font-family: 'Outfit Variable', sans-serif; font-weight: 700; font-size: 16px; padding: 16px 28px; border-radius: 14px; text-decoration: none; }
  .pg-note { margin-top: 12px; font-size: 13px; color: var(--muted); }
  .pg-block { padding: 60px 0; border-top: 1px solid rgba(255,255,255,0.06); }
  .pg h2 { font-family: 'Outfit Variable', sans-serif; font-size: clamp(26px, 3.5vw, 36px); font-weight: 800; letter-spacing: -0.015em; line-height: 1.15; margin: 0; }
  .pg-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 30px; }
  .pg-cards article { border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 24px; background: rgba(255,255,255,0.02); }
  .pg-cards h3 { font-family: 'Outfit Variable', sans-serif; font-size: 17px; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.25; }
  .pg-cards p { font-size: 14px; line-height: 1.6; color: var(--light-muted); margin: 0; }
  .pg-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 30px; }
  .pg-pnum { font-family: 'Outfit Variable', sans-serif; font-weight: 800; font-size: 14px; color: var(--green-bright); }
  .pg-pillars h3 { font-family: 'Outfit Variable', sans-serif; font-size: 20px; font-weight: 700; color: #fff; margin: 8px 0 8px; }
  .pg-pillars p { font-size: 14.5px; line-height: 1.6; color: var(--light-muted); margin: 0; }
  .pg-faq details { border-top: 1px solid rgba(255,255,255,0.08); padding: 18px 0; }
  .pg-faq summary { font-family: 'Outfit Variable', sans-serif; font-weight: 700; font-size: 17px; color: #fff; cursor: pointer; }
  .pg-faq p { font-size: 14.5px; line-height: 1.6; color: var(--light-muted); margin: 12px 0 0; }
  .pg-cta-block .pg-lead { margin-top: 16px; }
  .pg-footer { padding: 40px 0 64px; border-top: 1px solid rgba(255,255,255,0.06); font-size: 13px; color: var(--muted); }
  .pg-links { margin-top: 8px; }
  .pg-links a { color: var(--light-muted); text-decoration: underline; text-underline-offset: 3px; }
  @media (max-width: 720px) { .pg-cards, .pg-pillars { grid-template-columns: 1fr; } }
</style>
